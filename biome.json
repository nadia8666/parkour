{
	"linter": {
		"rules": {
			"style": {
				"useConst": "off",
				"useArrayLiterals": "off",
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noAssignInExpressions": "off",
				"useIterableCallbackReturn": "off",
				"noShadowRestrictedNames": "off"
			}
		}
	},
	"formatter": {
		"lineWidth": 180
	},
	"files": {
		"includes": ["Assets/Code/**/*.ts"]
	}
}
